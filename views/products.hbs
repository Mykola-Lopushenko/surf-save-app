<div class="header">
    <h2>Products</h2>
</div>

<div class="section">
    <h3>Add New Product</h3>
    <form action="/add-product" method="POST" class="form">
        <div class="form-group">
            <input type="text" name="productName" placeholder="Product Name" required>
            <input type="number" name="price" step="0.01" placeholder="Price" required min="0">
        </div>
        <div class="form-group">
            <select name="productTypeID" required>
                <option value="">Select Product Type</option>
                {{#each productTypes}}
                <option value="{{productTypeID}}">{{description}}</option>
                {{/each}}
            </select>
        </div>
        <button type="submit" class="btn">Add Product</button>
    </form>
</div>

<div class="section">
    <h3>Existing Products</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Product Name</th>
                <th>Price</th>
                <th>Product Type</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each products}}
            <tr>
                <td>{{productID}}</td>
                <td>{{productName}}</td>
                <td>{{price}}</td>
                <td>{{productTypeDescription}}</td>
                <td class="actions">
                    <button
                        type="button"
                        class="btn-sm"
                        onclick="loadProductForEdit('{{productID}}', '{{productName}}', '{{price}}', '{{productTypeID}}')">
                        Edit
                    </button>

                    <form action="/delete-product" method="POST" style="display: inline;"
                          onsubmit="return confirm('Are you sure you want to delete {{productName}}?')">
                        <input type="hidden" name="productID" value="{{productID}}">
                        <button type="submit" class="btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div class="section" id="editProductSection" style="display: none;">
    <h3>Edit Product</h3>
    <form action="/update-product" method="POST" class="form" onsubmit="return validateEditProductForm()">
        <input type="hidden" name="productID" id="editProductID">

        <div class="form-group">
            <input type="text" name="productName" id="editProductName" placeholder="Product Name *" required>
            <input type="number" step="0.01" min="0" name="price" id="editProductPrice" placeholder="Price *" required>
        </div>

        <div class="form-group">
            <select name="productTypeID" id="editProductTypeID" required>
                <option value="">Select Product Type *</option>
                {{#each productTypes}}
                <option value="{{productTypeID}}">{{description}}</option>
                {{/each}}
            </select>
        </div>

        <button type="submit" class="btn">Save Changes</button>
    </form>
</div>

<script>
function loadProductForEdit(productID, productName, price, productTypeID) {
    document.getElementById('editProductID').value = productID;
    document.getElementById('editProductName').value = productName;
    document.getElementById('editProductPrice').value = price;
    document.getElementById('editProductTypeID').value = productTypeID;

    document.getElementById('editProductSection').style.display = 'block';
    document.getElementById('editProductSection').scrollIntoView({ behavior: 'smooth' });
}

function validateEditProductForm() {
    const productName = document.getElementById('editProductName').value.trim();
    const price = document.getElementById('editProductPrice').value.trim();
    const productTypeID = document.getElementById('editProductTypeID').value;

    if (!productName || !price || !productTypeID) {
        alert('Please fill in all required fields');
        return false;
    }

    if (parseFloat(price) < 0) {
        alert('Price must be a positive number');
        return false;
    }

    return true;
}
</script>