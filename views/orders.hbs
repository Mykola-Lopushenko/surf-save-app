<div class="header">
    <h2>Order Management</h2>
</div>

<div class="section">
    <h3>Create New Order</h3>
    <form action="/add-order" method="POST" class="form">
        <div class="form-group">
            <select name="customerID" required>
                <option value="">Select Customer</option>
                {{#each customers}}
                <option value="{{customerID}}">{{firstName}} {{lastName}}</option>
                {{/each}}
            </select>
            <input type="number" name="totalCost" step="0.01" placeholder="Total Cost" required min="0">
        </div>
        <div class="form-group">
            <input type="date" name="orderDate" required>
            <input type="text" name="shippingAddress" placeholder="Shipping Address" required>
        </div>
        <button type="submit" class="btn">Create Order</button>
    </form>
</div>

<div class="section">
    <h3>Existing Orders</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Total Cost</th>
                <th>Order Date</th>
                <th>Shipping Address</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each orders}}
            <tr>
                <td>{{orderID}}</td>
                <td>{{customerName}}</td>
                <td>{{totalCost}}</td>
                <td>{{formatDate orderDate}}</td>
                <td>{{shippingAddress}}</td>
                <td class="actions">
                    <button
                        type="button"
                        class="btn-sm"
                        onclick="loadOrderForEdit('{{orderID}}', '{{customerID}}', '{{totalCost}}', '{{orderDate}}', '{{shippingAddress}}')">
                        Edit
                    </button>

                    <form action="/delete-order" method="POST" style="display: inline;"
                          onsubmit="return confirm('Are you sure you want to delete order #{{orderID}}?')">
                        <input type="hidden" name="orderID" value="{{orderID}}">
                        <button type="submit" class="btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div class="section" id="editOrderSection" style="display: none;">
    <h3>Edit Order</h3>
    <form action="/update-order" method="POST" class="form" onsubmit="return validateEditOrderForm()">
        <input type="hidden" name="orderID" id="editOrderID">

        <div class="form-group">
            <select name="customerID" id="editOrderCustomerID" required>
                <option value="">Select Customer *</option>
                {{#each customers}}
                <option value="{{customerID}}">{{firstName}} {{lastName}}</option>
                {{/each}}
            </select>

            <input type="number" step="0.01" name="totalCost" id="editOrderTotalCost" placeholder="Total Cost *" required>
        </div>

        <div class="form-group">
            <input type="date" name="orderDate" id="editOrderDate" required>
            <input type="text" name="shippingAddress" id="editOrderShippingAddress" placeholder="Shipping Address *" required>
        </div>

        <button type="submit" class="btn">Save Changes</button>
    </form>
</div>

<script>
function loadOrderForEdit(orderID, customerID, totalCost, orderDate, shippingAddress) {
    document.getElementById('editOrderID').value = orderID;
    document.getElementById('editOrderCustomerID').value = customerID;
    document.getElementById('editOrderTotalCost').value = totalCost;

    const formattedDate = formatDateForInput(orderDate);
    document.getElementById('editOrderDate').value = formattedDate;

    document.getElementById('editOrderShippingAddress').value = shippingAddress;
    document.getElementById('editOrderSection').style.display = 'block';
    document.getElementById('editOrderSection').scrollIntoView({ behavior: 'smooth' });
}

function formatDateForInput(dateString) {
    const date = new Date(dateString);
    if (isNaN(date.getTime())) return '';

    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');

    return `${year}-${month}-${day}`;
}

function validateEditOrderForm() {
    const customerID = document.getElementById('editOrderCustomerID').value;
    const totalCost = document.getElementById('editOrderTotalCost').value.trim();
    const orderDate = document.getElementById('editOrderDate').value.trim();
    const shippingAddress = document.getElementById('editOrderShippingAddress').value.trim();

    if (!customerID || !totalCost || !orderDate || !shippingAddress) {
        alert('Please fill in all required fields');
        return false;
    }

    if (parseFloat(totalCost) < 0) {
        alert('Total cost must be a positive number');
        return false;
    }

    return true;
}
</script>